# Server Configuration
PORT=5000
NODE_ENV=development

# AI Provider Configuration (at least ONE key recommended)
# Priority: Gemini (free) → Groq (free) → OpenAI (paid) → Fallback

# Google Gemini (FREE - 15 req/min, 1M tokens/day)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (FREE - 30 req/min, Llama 3.3 70B)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (PAID - optional)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# API Security (Optional)
# Set to 'true' to require API keys for all requests
REQUIRE_API_KEY=false
# Comma-separated list of valid API keys (if REQUIRE_API_KEY=true)
API_KEYS=

# Rate Limiting Configuration (Optional - defaults are set in code)
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
# RATE_LIMIT_MAX_REQUESTS=100
# AI_RATE_LIMIT_MAX=10

# Security Headers (Optional)
# ENABLE_HELMET=true
# ENABLE_CORS=true

# Logging (Optional)
# LOG_LEVEL=info
# ENABLE_AUDIT_LOG=true
