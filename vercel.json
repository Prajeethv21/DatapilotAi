{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install && cd server && npm install && cd ../client && npm install",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/chat/message", "destination": "/api/chat" },
    { "source": "/api/chat/analyze", "destination": "/api/chat" },
    { "source": "/api/upload/file", "destination": "/api/upload" },
    { "source": "/api/upload/database", "destination": "/api/upload" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
